{
  "name": "ledgerlink",
  "version": "1.0.0",
  "description": "A modern web application built with Django REST Framework and React with Material UI",
  "scripts": {
    "lint": "node ./claude-lint-fullstack.js",
    "lint:watch": "node ./claude-lint-fullstack.js --watch",
    "lint:claude": "node ./claude-lint-fullstack.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run",
    "test:e2e:ci": "cypress run --headless",
    "test:pact": "jest --config=frontend/pact/jest.config.js",
    "test:pact:publish": "node frontend/pact/publish.js",
    "test:pact:verify": "pytest -xvs api/tests/pact/"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "glob": "^11.0.1",
    "ignore": "^5.3.2"
  },
  "devDependencies": {
    "cypress": "^13.6.0",
    "cypress-axe": "^1.5.0",
    "axe-core": "^4.8.2",
    "start-server-and-test": "^2.0.0",
    "@pact-foundation/pact": "^12.1.0",
    "@pact-foundation/pact-node": "^10.17.7"
  }
}
