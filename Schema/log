    customer_id INT NOT NULL REFERENCES customers(customer_id) ON DELETE CASCADE,  -- Customer who owns the toy
    labeling_unit_1 VARCHAR(50),  -- Details about the toy
    labeling_quantity_1 INT CHECK (labeling_quantity_1 >= 0),  -- More details
    -- ... more details ...
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,  -- When the toy was added
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP  -- When the toy details were last updated
) PARTITION BY HASH (customer_id);  -- Split the toys based on the customer ID
Create the Smaller Tables (Partitions)
